HOST = "0.0.0.0"
PORT = 8899

BASE_DIR = r"" #Adicionar diretorio onde ficará salvo os arquivos

PASTA_ENVIAR = os.path.join(BASE_DIR, "ENVIAR")
PASTA_RECEBER = os.path.join(BASE_DIR, "RECEBER")
PASTA_LOG = os.path.join(BASE_DIR, "LOG")
XON  = b'\x11'
XOFF = b'\x13'

#Sepração de máquina por IP
MAQUINA_POR_IP = {
    "192.168.0.8": "CNC01",
    "192.168.0.9": "CNC02",
    "192.168.0.10": "CNC03",
    "192.168.0.11": "CNC04",
